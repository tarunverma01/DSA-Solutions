class Solution {
public:
    int todo(int index, vector<int>&nums, vector<int>& dp){
        if(index>=nums.size()) return 0;
        if(dp[index]!=-1) return dp[index];
        int robb = nums[index] + todo(2+index,nums,dp);
        int skip = todo(1+index,nums,dp);
        return dp[index]=max(skip,robb);
    }
    int rob(vector<int>& nums) {
       vector<int>dp(nums.size(),-1);
       return todo(0,nums,dp);
    }
};
